{
  "name": "solo-founder-launch-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/api",
    "packages/web",
    "packages/infra"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm run build --workspace=packages/api",
    "build:web": "npm run build --workspace=packages/web",
    "test": "npm run test --workspace=packages/api && npm run test --workspace=packages/web",
    "test:api": "npm run test --workspace=packages/api",
    "test:web": "npm run test --workspace=packages/web",
    "cdk:synth": "npm run synth --workspace=packages/infra",
    "cdk:deploy": "npm run deploy --workspace=packages/infra",
    "test:infra": "npm run test --workspace=packages/infra",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "setup:secrets": "tsx scripts/setup-secrets.ts",
    "check:bundle": "tsx scripts/check-bundle.ts",
    "check:readiness": "tsx scripts/check-readiness.ts",
    "verify:monitoring": "tsx scripts/verify-monitoring.ts",
    "test:load": "k6 run load-tests/load-test.js",
    "test:scripts": "vitest run --config scripts/vitest.config.ts"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "devDependencies": {
    "@aws-sdk/client-acm": "^3.700.0",
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@aws-sdk/client-cloudfront": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/client-route-53": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0"
  }
}
