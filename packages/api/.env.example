# ============================================
# Solo Founder Launch OS - API Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --------------------------------------------
# Database
# --------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/solo_founder_launch_os?schema=public"

# --------------------------------------------
# GitHub OAuth
# --------------------------------------------
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set the Authorization callback URL to your GITHUB_CALLBACK_URL below

# GitHub OAuth App Client ID
GITHUB_CLIENT_ID="your_github_client_id"

# GitHub OAuth App Client Secret
GITHUB_CLIENT_SECRET="your_github_client_secret"

# OAuth callback URL (must match the one configured in your GitHub OAuth App)
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"

# --------------------------------------------
# Encryption
# --------------------------------------------
# 32-byte hex key for AES-256-GCM encryption of GitHub access tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your_64_char_hex_encryption_key_here_generate_with_crypto"

# --------------------------------------------
# LLM / AI
# --------------------------------------------
# OpenAI API key for content generation (changelog, social posts, etc.)
# Get your key at: https://platform.openai.com/api-keys
LLM_API_KEY="sk-your_openai_api_key_here"

# --------------------------------------------
# Session
# --------------------------------------------
# Secret used to sign session cookies (use a long random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="your_session_secret_here_use_a_long_random_string"

# --------------------------------------------
# Server
# --------------------------------------------
# Port the API server listens on
PORT=3001

# Environment mode: development | production | test
NODE_ENV=development

# --------------------------------------------
# CORS
# --------------------------------------------
# Frontend URL for CORS origin allowlist
# In development, this is typically the Vite dev server
FRONTEND_URL="http://localhost:5173"

# --------------------------------------------
# Amazon Bedrock (Content Generation)
# --------------------------------------------
# Foundation model ID for content generation (default: amazon.nova-pro-v1:0)
BEDROCK_MODEL_ID="amazon.nova-pro-v1:0"

# AWS region for Bedrock API calls (default: us-east-1)
BEDROCK_REGION="us-east-1"

# Enable/disable Bedrock integration (false = use template fallback)
BEDROCK_ENABLED="false"
